# =================================================================
# .env.example
# -----------------------------------------------------------------
# Copy to `.env` and customize. .env is git-ignored.
# Anything here can also be set via shell or CI secrets.
# =================================================================

# Which env to test against: dev | staging | prod
TEST_ENV=staging

# Logging
LOG_LEVEL=info
WDIO_LOG_LEVEL=info

# How many devices to run in parallel (must match connected devices)
MAX_INSTANCES=1

# Appium server (default 4723)
APPIUM_PORT=4723

# Override credentials without committing them (production safety)
TEST_USERNAME=
TEST_PASSWORD=

# ---- Android ----
ANDROID_PLATFORM_VERSION=13.0
ANDROID_DEVICE_NAME=emulator-5554
ANDROID_APP_PACKAGE=com.swaglabsmobileapp
ANDROID_APP_ACTIVITY=.MainActivity

# ---- iOS (macOS only) ----
IOS_PLATFORM_VERSION=17.4
IOS_DEVICE_NAME=iPhone 15
IOS_BUNDLE_ID=com.saucelabs.SwagLabsMobileApp

# Path override - point to YOUR locally-stored APK / .app
APP_PATH=
