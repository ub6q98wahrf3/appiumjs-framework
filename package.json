{
  "name": "appium-mobile-framework",
  "version": "1.0.0",
  "description": "Appium + WebdriverIO mobile automation framework for native apps with POM, OOP, parallel execution, Allure, and CI/CD",
  "type": "module",
  "scripts": {
    "appium:install": "appium driver install uiautomator2 && appium driver install xcuitest",
    "appium:doctor:android": "appium-doctor --android",
    "appium:doctor:ios": "appium-doctor --ios",
    "test:android": "wdio run ./config/wdio.android.conf.js",
    "test:ios": "wdio run ./config/wdio.ios.conf.js",
    "test:ci:android": "wdio run ./config/wdio.ci.android.conf.js",
    "test:ci:ios": "wdio run ./config/wdio.ci.ios.conf.js",
    "test:smoke:android": "wdio run ./config/wdio.android.conf.js --mochaOpts.grep @smoke",
    "test:smoke:ios": "wdio run ./config/wdio.ios.conf.js --mochaOpts.grep @smoke",
    "test:regression:android": "wdio run ./config/wdio.android.conf.js --mochaOpts.grep @regression",
    "test:regression:ios": "wdio run ./config/wdio.ios.conf.js --mochaOpts.grep @regression",
    "test:login:android": "wdio run ./config/wdio.android.conf.js --spec ./test/specs/login.spec.js",
    "test:login:ios": "wdio run ./config/wdio.ios.conf.js --spec ./test/specs/login.spec.js",
    "test:parallel:android": "MAX_INSTANCES=2 wdio run ./config/wdio.android.conf.js",
    "report:generate": "allure generate ./reports/allure-results --clean -o ./reports/allure-report",
    "report:open": "allure open ./reports/allure-report",
    "report": "npm run report:generate && npm run report:open",
    "clean": "rimraf ./reports ./screenshots ./logs",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --write \"**/*.{js,json,md}\"",
    "prepare": "husky install || true"
  },
  "keywords": [
    "appium",
    "webdriverio",
    "wdio",
    "mobile",
    "automation",
    "native",
    "android",
    "ios",
    "pom",
    "allure"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@wdio/allure-reporter": "^9.0.0",
    "@wdio/appium-service": "^9.0.0",
    "@wdio/cli": "^9.0.0",
    "@wdio/junit-reporter": "^9.0.0",
    "@wdio/local-runner": "^9.0.0",
    "@wdio/mocha-framework": "^9.0.0",
    "@wdio/spec-reporter": "^9.0.0",
    "allure-commandline": "^2.27.0",
    "appium": "^2.11.0",
    "appium-doctor": "^1.16.2",
    "appium-uiautomator2-driver": "^3.0.0",
    "appium-xcuitest-driver": "^7.0.0",
    "chai": "^5.1.1",
    "dotenv": "^16.4.5",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-wdio": "^9.0.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.3.0",
    "rimraf": "^6.0.0",
    "winston": "^3.13.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
